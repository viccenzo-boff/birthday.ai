generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Na versão 7, não colocamos mais a URL aqui! 
  // O Prisma vai ler a conexão direto do prisma.config.ts e do .env
}

model Aniversariante {
  id              String     @id @default(uuid())
  nome            String
  apelido         String?    // O ponto de interrogação (?) torna o campo opcional
  data_nascimento DateTime
  ativo           Boolean    @default(true)
  data_criacao    DateTime   @default(now())
  logs            LogEnvio[] // Indica que um aniversariante pode ter vários logs de envio
}

model LogEnvio {
  id               String         @id @default(uuid())
  status           String         // "SUCESSO" ou "ERRO"
  detalhe_erro     String?        // Guarda a mensagem de erro se o disparo falhar
  data_envio       DateTime       @default(now())
  
  // Relacionamento: Vincula o log diretamente ao aniversariante correspondente
  aniversarianteId String
  aniversariante   Aniversariante @relation(fields: [aniversarianteId], references: [id], onDelete: Cascade)
}